{
  "name": "Grand Archive",
  "menuBackgroundImage": "https://saltypony290.github.io/Grand_Archive_TCG/grand_archive_banner.png",
  "defaultRessources": {
    "backgrounds": [
      "https://saltypony290.github.io/Grand_Archive_TCG/grand_archive_bg.png"
    ],
    "decksUrl": "https://saltypony290.github.io/Grand_Archive_TCG/GrandArchiveDecks.json"
  },

  "customHelp": "(1) Place your level 0 champion from the Material Deck onto the Champion zone.\n(2) Materialize regalia and champion upgrades from the Material Deck.\n(3) Actions and attacks go to the Stack, then move them to Graveyard after resolution.\n(4) Use counters to track damage and buffs.\n(5) Memory is hidden/private. Banishment is public.\n(6) Allies, Domains, Regalia, and Phantasia auto-place when played.",

  "cardRotation": 0,

  "cards": {
    "dataUrl": "https://saltypony290.github.io/Grand_Archive_TCG/grand_archive_cards.json",
    "cardBack": "https://saltypony290.github.io/Grand_Archive_TCG/card_back.jpg"
  },

  "deckBuilding": {
    "mainFilters": [
      "type",
      "cost",
      "name",
      "Element",
      "Class",
      "Set"
    ],
    "formats": [
      {
        "title": "Standard",
        "gameplay": "GrandArchive",
        "customCategories": ["Material Deck"],
        "deckRuleset": "Standard"
      }
    ],
    "deckRulesets": {
      "Standard": {
        "general": {
          "min": 72,
          "max": 72,
          "maxPerCard": 4
        },
        "categories": [
          {
            "category": "Material Deck",
            "min": 12,
            "max": 12,
            "maxPerCard": 1
          }
        ]
      }
    }
  },

  "gameplay": {
    "GrandArchive": {

      "mulligan": {
        "info": "Grand Archive has no mulligan. Start by placing a level 0 champion into play.",
        "startingHandSize": 0,
        "triggeredByButton": "false",
        "drawNewHand": false,
        "putSelectionAtBottom": false,
        "drawNewSelectedCards": false
      },

      "categoriesAlreadyOnBoard": ["Champion"],

      "beforeGameStart": {
        "initialBoardSetup": []
      },

      "newTurn": {
        "drawOnStart": true,
        "sharedTurn": false,
        "firstPlayerTokenName": "",
        "drawPerTurn": 1
      },

      "defaultNotes": "Track damage with counters. Stack resolves manually. Memory is hidden.",

      "tokens": [],

      "draggableTokens": [
        {
          "id": "Damage",
          "name": "Damage",
          "image": "https://dummyimage.com/128x128/cc0000/ffffff&text=DMG"
        },
        {
          "id": "Durability",
          "name": "Durability",
          "image": "https://dummyimage.com/128x128/555555/ffffff&text=DUR"
        }
      ],

      "countersStartingValues": [0],
      "hideFacedDownCards": true,

      "sections": {

        "customSections": [
          "Champion",
          "Allies",
          "Regalia",
          "Domains",
          "Phantasia",
          "Intent",
          "Memory",
          "Banishment",
          "Stack"
        ],

        "layout": {
          "direction": "row",
          "isSymetricalForOpponents": true,
          "content": [
            {
              "direction": "column",
              "style": { "width": "70%" },
              "content": [
                {
                  "direction": "row",
                  "content": [
                    { "section": "Domains" },
                    { "section": "Champion" },
                    { "section": "Regalia" }
                  ]
                },
                { "section": "Allies" },
                { "section": "Phantasia" },
                { "section": "Intent" },
                { "section": "Stack" }
              ]
            },
            {
              "direction": "column",
              "style": { "width": "24vh" },
              "content": [
                { "section": "Memory" },
                { "section": "Banishment" }
              ]
            }
          ]
        },

        "autoPlayFromHand": {
          "CHAMPION": "Champion",
          "ALLY": "Allies",
          "ACTION": "Stack",
          "ATTACK": "Stack",
          "DOMAIN": "Domains",
          "PHANTASIA": "Phantasia",
          "ITEM": "Regalia",
          "WEAPON": "Regalia"
        },

        "autoPlayFromStack": {
          "CHAMPION": "Champion",
          "ALLY": "Allies",
          "ACTION": "Banishment",
          "ATTACK": "Banishment",
          "DOMAIN": "Domains",
          "PHANTASIA": "Phantasia",
          "ITEM": "Regalia",
          "WEAPON": "Regalia"
        },

        "sectionsDict": {

          "Champion": {
            "title": "Champion",
            "height": "MEDIUM",
            "alignment": "CENTER",
            "isGroupForbidden": true
          },

          "Allies": {
            "title": "Allies",
            "height": "MEDIUM",
            "alignment": "CENTER"
          },

          "Regalia": {
            "title": "Regalia",
            "height": "SMALL",
            "alignment": "CENTER",
            "isHorizontalAllowed": true
          },

          "Domains": {
            "title": "Domains",
            "height": "SMALL",
            "alignment": "CENTER"
          },

          "Phantasia": {
            "title": "Phantasia",
            "height": "SMALL",
            "alignment": "CENTER"
          },

          "Intent": {
            "title": "Intent",
            "height": "SMALL",
            "alignment": "CENTER"
          },

          "Stack": {
            "title": "Stack",
            "height": "HUGE",
            "alignment": "CENTER",
            "isDefaultSection": true,
            "isGroupForbidden": true
          },

          "Memory": {
            "title": "Memory",
            "isHidden": "yes",
            "alignment": "END"
          },

          "Banishment": {
            "title": "Banishment",
            "alignment": "END"
          }
        }
      }
    }
  }
}
